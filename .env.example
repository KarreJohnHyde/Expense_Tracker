# Get your free ngrok auth token from https://dashboard.ngrok.com/get-started/your-authtoken
# Rename this file to .env and add your token below
NGROK_AUTHTOKEN=your_auth_token_here

# Optional: Live market data (Twelve Data)
# Add a Twelve Data API key to enable real-time stock/crypto/forex quotes.
TWELVEDATA_API_KEY=your_twelvedata_api_key_here
# Or call Twelve Data directly from the client (not recommended for private keys):
VITE_TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Optional: use local market proxy with the Vite frontend
VITE_MARKET_API_BASE=http://localhost:3001
